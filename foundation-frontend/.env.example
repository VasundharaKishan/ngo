# ===================================
# Frontend Environment Variables
# ===================================

# API BASE URL
# Points to your backend API endpoint
# Local development: http://localhost:8080/api
# Staging: https://your-staging-backend.onrender.com/api
# Production: https://your-production-backend.railway.app/api
VITE_API_BASE_URL=http://localhost:8080/api

# SENTRY (error monitoring)
# Get your DSN from https://sentry.io → Project Settings → Client Keys
# Leave blank to disable Sentry
VITE_SENTRY_DSN=

# GOOGLE ANALYTICS
# Get your Measurement ID from https://analytics.google.com → Admin → Data Streams
# Format: G-XXXXXXXXXX
# Leave blank to disable analytics
VITE_GA_MEASUREMENT_ID=

# ===================================
# DEPLOYMENT NOTES
# ===================================

# For Netlify:
# 1. Build command: npm run build
# 2. Publish directory: dist
# 3. Add environment variable: VITE_API_BASE_URL=https://your-backend-url.com/api

# For Vercel:
# 1. Build command: npm run build
# 2. Output directory: dist
# 3. Add environment variable: VITE_API_BASE_URL=https://your-backend-url.com/api
