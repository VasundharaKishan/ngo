# Patch for foundation-frontend/src/App.tsx
#
# Adds the /refund route + lazy import for RefundPage.tsx so that the
# footer link `<Link to="/refund">` (Layout.tsx line ~272) resolves to
# the new Refund & Cancellation Policy page instead of falling through
# to the `*` -> NotFound catch-all.
#
# App.tsx is in the user's in-flight uncommitted set, so this patch is
# kept separate from the main blocker commit. Apply after the RefundPage
# file lands.
#
# Usage:
#   cd <repo root>
#   git apply patches/0002-app-tsx-refund-route.patch
#
# If the hunks don't apply cleanly (e.g. because surrounding lazy imports
# shifted in your in-flight edit), apply the two edits by hand.
#
# --- a/foundation-frontend/src/App.tsx
# +++ b/foundation-frontend/src/App.tsx
#
# @@ change 1: add the lazy import next to the other legal pages.
#  const TermsPage = lazy(() => import('./pages/TermsPage'));
#  const PrivacyPage = lazy(() => import('./pages/PrivacyPage'));
#  const AccessibilityPage = lazy(() => import('./pages/AccessibilityPage'));
#  const CookiesPage = lazy(() => import('./pages/CookiesPage'));
# +const RefundPage = lazy(() => import('./pages/RefundPage'));
#  const AboutPage = lazy(() => import('./pages/AboutPage'));
#
# @@ change 2: wire the public route alongside the other legal routes.
#               <Route path="/terms" element={<TermsPage />} />
#               <Route path="/privacy" element={<PrivacyPage />} />
#               <Route path="/accessibility" element={<AccessibilityPage />} />
#               <Route path="/cookies" element={<CookiesPage />} />
# +             <Route path="/refund" element={<RefundPage />} />
#               <Route path="*" element={<NotFound />} />
#
# Verification after applying:
#   * Visit /refund — should render the policy (no 404).
#   * Footer "Refund policy" link (Layout.tsx) should navigate correctly.
#   * npm run build should succeed with the new lazy chunk.
#   * If you add Playwright coverage, add to the existing legal-pages spec:
